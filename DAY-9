//problem no--5
//linear search

#include <iostream>
using namespace std;

 
int LinearSearch(int arr[], int size, int targetValue){
    for(int i=0; i< size; i++){
        if(arr[i]==targetValue){
            return i;//retruns the index value of the target element
        }
    }
    return -1;
}

int main() {
    int arr[] = {10,20,30,40,50};
    int targetIndex= LinearSearch(arr, 5, 40);
    cout<< "Target is found at"<<" " << targetIndex << endl;
    LinearSearch (arr, 5, 20);
}
