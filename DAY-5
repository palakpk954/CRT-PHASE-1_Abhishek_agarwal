//Problem--5
//Function overloading

#include <iostream>
using namespace std;

int add(int a, int b){
    return a+b;
}

int add(int a, int b, int c){
    return a+b+c;
}

int add(int a, int b, int c, int d){
    return a+b+c+d;
}

double add(double a, double b){
    return a+b;
}
int main(){
    cout << add(5,2) << "\n";
    cout << add(5,2,3)  << "\n";
    cout << add(5,2,3,4)  << "\n";
    cout << add(5.3,2.8);
   
    return 0;
}


//Problem--6
//pointers 

#include <iostream>
using namespace std;

int main(){
    int age = 24;
    int *ptr= &age;
    
    //with the help of variable
    cout << age << "\n";
    //printing the address of the variable
    cout << ptr << "\n";
    //using derefrencing with the help of pointer we are getting variable
    cout << *ptr << "\n";
    
    // to change the value of variable using pointer
    //age =28
    *ptr = 28;
    cout << *ptr;
    
    return 0;
}







