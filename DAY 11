//Q1.  pallindrome

#include<iostream>
using namespace std;
bool isPalindrome(string str){
    int start = 0;
    int end = str.size() -1;
    while(start < end){
        if(str[start] == str[end]){
            return true;
        }
        start++;
        end--;
    }
    return false;
}
int main(){
    string str;
    cout << "enter a string= ";
    cin >> str;
    if(isPalindrome(str)){
        cout << "pallindrome string";
    }
    else{
        cout << "given string is not a pallindrome";
    }
    return 0;
}

