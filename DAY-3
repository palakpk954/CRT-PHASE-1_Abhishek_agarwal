#include <iostream>
using namespace std;

int main() {

    // --------------------------------------------------------
    // Problem 1 — Print 1 to 10 using a for loop
    // --------------------------------------------------------
    cout << "Problem 1 (for, ascending):   ";
    for (int i = 1; i <= 10; i++) {
        cout << i << " ";
    }
    cout << "\n";

    // --------------------------------------------------------
    // Problem 2 — Print 10 to 1 using a for loop
    // --------------------------------------------------------
    cout << "Problem 2 (for, descending):  ";
    for (int i = 10; i >= 1; i--) {
        cout << i << " ";
    }
    cout << "\n";

    // --------------------------------------------------------
    // Problem 3 — Print 1 to 10 using a while loop
    // --------------------------------------------------------
    cout << "Problem 3 (while, ascending): ";
    int i = 1;
    while (i <= 10) {
        cout << i << " ";
        i++;
    }
    cout << "\n";

    // --------------------------------------------------------
    // Problem 4 — Print 10 to 1 using a while loop
    // --------------------------------------------------------
    cout << "Problem 4 (while, descending):";
    i = 10;
    while (i >= 1) {
        cout << i << " ";
        i--;
    }
    cout << "\n";

    // --------------------------------------------------------
    // Problem 5 — Print 1 to 10 using a do-while loop
    // --------------------------------------------------------
    cout << "Problem 5 (do-while, asc):    ";
    i = 1;
    do {
        cout << i << " ";
        i++;
    } while (i <= 10);
    cout << "\n";

    // --------------------------------------------------------
    // Problem 6 — Print 10 to 1 using a do-while loop
    // --------------------------------------------------------
    cout << "Problem 6 (do-while, desc):   ";
    i = 10;
    do {
        cout << i << " ";
        i--;
    } while (i >= 1);
    cout << "\n";

    return 0;
}
