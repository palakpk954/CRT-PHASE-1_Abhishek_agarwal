Valid Anagram 
class Solution {
public:
    bool isAnagram(string s, string t) {

        if(s.size() != t.size()) {
            return false;
        }

        sort(s.begin(), s.end());
        sort(t.begin(), t.end());
        if(s == t){
            return true;
        }else {
            return false;
        }
    }
};

LeetCode 342
Reverse String 
class Solution {
public:
    void reverseString(vector<char>& s) {

        int left = 0;
        int right = s.size() - 1;

        while(left < right) {
            char c = s[right];
            s[right] = s[left];
            s[left] = c;

            left++;
            right--;
        }
    }
};

