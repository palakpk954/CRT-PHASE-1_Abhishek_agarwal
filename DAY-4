//Problem no--1
//Print 1-10, 10 no. of times

#include <iostream>
using namespace std;

int main()
{
    //number of times to print the patterns
    for (int i=1; i<=10; i++){
        //this defines what to print in pattern
        for(int j = 1; j<=10; j++){
            cout<<j<< " ";
        }
        cout<< "\n";
    }
}


