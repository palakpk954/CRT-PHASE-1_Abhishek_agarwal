//PROBLEM: 1
//TO REVERSE AN ARRAY USING STACK

#include <stack>
#include <iostream>
using namespace std;

int main()
{
   int arr[]={10,20,30,40,50};
   int n = 5;
   
   stack<int> st;
   for (int i=0; i<n; i++){
       st.push(arr[i]);
   }
   
   for (int i=0; i<n; i++){
       arr[i]=st.top();
       st.pop();
   }
   
   cout<<"Reversed array"<<"\n";
   for(int i =0; i<n; i++){
       cout<< arr[i]<<" ";
   }
    return 0;
}

//PROBLEM 2: Reverse the string using stack

class Solution {
public:
void reverseString(vector<char> & s){
    stack<char> st;

    for(int i = 0; i<s.size(); i++){
        st.push(s[i]);
    }

    int i =0;
    while( ! st.empty()){
        s[i++]= st.top();
        st.pop();
    }
}
};
