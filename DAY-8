#include<iostream>
using namespace std;

class Animal{
    public:
    virtual void sound(){
        cout<< "Animal makes sound"<<endl;
    }
};

class Dog:public Animal{
    public:
    void sound() override {
        cout<< " Dog makes a sound"<<endl;
        
    }
};

class Cat:public Animal{
    public:
    void sound() override {
        cout<< " Cat makes a sound"<<endl;
        
    }
};


int main() {
    
    Dog d;
    Cat c;
    d.sound();
    c.sound();
    
}




