//problem--3
//call by value// call by reference
//call by value-- photocopy
//call by refrence-- original copy
#include <iostream>
using namespace std;

void updatebyValue(int a){
    a=500;
}

void updatebyRef(int &a){
    a=500;
}

int main(){
    int original = 100;
    cout<< original << "\n";
    
    updatebyValue(original);
    cout<< original << "\n";
    updatebyRef(original);
    cout<< original;
    
}

